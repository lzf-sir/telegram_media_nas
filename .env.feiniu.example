# ============================================================
# Telegram Media NAS - 飞牛 NAS 环境变量配置
# ============================================================
# 复制此文件为 .env 并填写实际值：
#   cp .env.feiniu.example .env
# ============================================================

# ---------- Telegram API 凭证（必填）----------
# 前往 https://my.telegram.org/apps 获取
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=your_phone_number

# ---------- Telegram Bot（可选）----------
# 从 @BotFather 获取，用于 Bot 命令任务
TELEGRAM_BOT_TOKEN=

# ---------- 安全设置 ----------
# JWT 密钥，请修改为随机字符串（可用: openssl rand -hex 32）
SECRET_KEY=change-this-secret-key-in-production

# ---------- 下载设置 ----------
# 最大并发下载数（NAS 性能有限，建议 2-3）
MAX_CONCURRENT_DOWNLOADS=3
# 下载失败最大重试次数
MAX_RETRIES=3

# ---------- 前端访问 ----------
# 飞牛 NAS 的访问地址，多个地址用英文逗号分隔
# 例如飞牛内网 IP 是 192.168.1.100，则填写:
# FRONTEND_ORIGINS=http://192.168.1.100:13500,http://localhost:13500
FRONTEND_ORIGINS=http://localhost:13500
